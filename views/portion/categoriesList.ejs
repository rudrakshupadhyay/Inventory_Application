<label for="category">Category:</label>

<select name="category" id="category" required>
  <% categories.forEach(category => { %>
    <option
      value="<%= category.id %>"
      <%= Number(book?.category_id || book?.category) === category.id ? "selected" : "" %>>
      <%= category.name %>
    </option>
  <% }) %>
</select>