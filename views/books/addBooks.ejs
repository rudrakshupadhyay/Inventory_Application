<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Book Form</title>
    <link rel="stylesheet" href="/addBooksStyle.css">
  </head>
  <body>
    <%- include("../portion/header.ejs") %>
    <div class="container">
      <h1 class="page-title"><%= title %></h1>
      <%- include("../portion/errors") %>
      <form action="<%= isEdit ? `/books/${book.id}/edit` : '/books/add' %>" method="post" class="addBookForm">
        <div class="form-group">
          <label for="title">Title:</label>
          <input
            type="text"
            name="title"
            id="title"
            placeholder="e.g., 1984"
            value="<%= book ? book.title : '' %>"
            required
          />
        </div>
        <div class="form-group">
          <label for="isbn">Isbn:</label>
          <input
            type="text"
            name="isbn"
            placeholder="e.g., 9780132350884"
            id="isbn"
            value="<%= book ? book.isbn : '' %>"
            required
          />
        </div>
        <div class="form-group">
          <label for="lang">Language:</label>
          <input type="text" name="language" placeholder="e.g., English" value="<%= book ? book.language : '' %>" id="lang" />
        </div>
        <div class="form-group">
          <label for="edition">Edition:</label>
          <input
            type="text"
            name="edition"
            id="edition"
            value="<%= book ? book.edition : '' %>"
            placeholder="e.g., 1st, 2nd, 3rd, Revised Edition"
          />
        </div>
        <div class="form-group">
          <label for="price">Book Price:</label>
          <input
            type="number"
            id="price"
            name="price"
            placeholder="e.g., 25.99"
            min="0"
            step="0.01"
            value="<%= book ? book.price : '' %>"
            required
          />
        </div>
        <div class="form-group">
          <label for="quantity">Quantity:</label>
          <input
            type="number"
            id="quantity"
            name="quantity"
            placeholder="e.g., 5"
            min="0"
            step="1"
            value="<%= book ? book.quantity : '' %>"
          />
        </div>
        <div class="form-group">
          <label for="description">Description:</label>
          <textarea
            id="description"
            name="description"
            rows="4"
            cols="50"
            placeholder="Enter book description"
          ><%= book ? book.description : '' %></textarea>
        </div>
        <div class="form-group">
          <%- include("../portion/categoriesList.ejs",{categories:categories,book}) %>
        </div>
        <div class="form-group">
          <%- include("../portion/authorsList.ejs",{authors:authors,book}) %>
        </div>
        <div class="form-group">
          <%- include("../portion/publishersList.ejs",{publishers:publishers,book}) %>
        </div>
        <button type="submit" class="btnAddBook">Submit</button>
      </form>
    </div>
  </body>
</html>
